NODE_ENV=development
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-a-long-random-secret

NEXT_PUBLIC_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

MONGODB_URI=mongodb://localhost:27017/barbdegree2
MONGODB_URI_LOCAL=mongodb://localhost:27017/barbdegree2
MONGODB_URI_CLOUD=

# Optional cache/rate-limit accelerator.
# Leave blank to use MongoDB-backed rate limiting without Redis.
# Use redis://localhost:6379 when running Redis locally.
# Docker Compose overrides this with redis://redis:6379.
REDIS_URL=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Also supported for hosted platforms that use these names:
# GOOGLE_ID=
# GOOGLE_SECRET=
# AUTH_GOOGLE_ID=
# AUTH_GOOGLE_SECRET=

PAYSTACK_SECRET_KEY=
PAYSTACK_WEBHOOK_SECRET=

LUMIID_SECRET_KEY=
